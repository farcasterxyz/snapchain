{
  "name": "client-parity-tests",
  "version": "1.0.0",
  "description": "Client parity tests",
  "license": "MIT",
  "scripts": {
    "test": "jest",
    "generate-messages": "ts-node generate-messages.ts"
  },
  "dependencies": {
    "@farcaster/core": "0.19.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "ts-node": "^10.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test.ts",
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "**/test.ts",
      "**/*.test.ts",
      "!**/node_modules/**"
    ]
